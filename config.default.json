{
  "telegram": {
    "sessionFile": "sessions/mtcute-user.session",
    "pollingLockFile": "data/bot-polling.lock"
  },
  "database": {
    "path": "data/posts.sqlite"
  },
  "logging": {
    "logLevel": "INFO",
    "color": "auto"
  },
  "shutdown": {
    "timeoutMs": 30000
  },
  "rateLimit": {
    "mtprotoGroup": "local",
    "maxQueueDelayMs": 300000,
    "longWaitWarnMs": 10000,
    "telegramOperationTimeoutMs": 60000,
    "redis": {
      "enabled": false,
      "required": false,
      "mode": "standalone",
      "url": "redis://127.0.0.1:6379",
      "keyPrefix": "tg-memes:local",
      "connectTimeoutMs": 3000,
      "operationTimeoutMs": 1000,
      "circuitBreakMs": 5000,
      "fallbackMultiplier": 3,
      "warningIntervalMs": 30000,
      "keyTtlMs": 86400000,
      "penaltyTtlMs": 3600000,
      "penaltyQuietPeriodMs": 60000,
      "penaltyDecayIntervalMs": 30000
    }
  },
  "sync": {
    "initialScanDays": 60,
    "refreshRecentDays": 7,
    "pageSize": 100,
    "maxPagesPerRun": 10000,
    "mediaDir": "tmp/media",
    "intervalHours": 6,
    "runOnStart": true,
    "retentionDays": 60,
    "retentionInitialDelayMinutes": 15,
    "retentionIntervalHours": 24,
    "throttle": {
      "enabled": true,
      "historyMinMs": 800,
      "historyMaxMs": 1800,
      "mediaMinMs": 300,
      "mediaMaxMs": 900,
      "reactionsMinMs": 3000,
      "reactionsMaxMs": 4000,
      "retryBufferMs": 1000
    },
    "maxRetries": 3,
    "retryBaseMs": 2000,
    "retryMaxMs": 60000,
    "maxMissingRatio": 0.3,
    "mediaMaxBytes": 536870912,
    "mediaMaxAgeHours": 24
  },
  "parsing": {
    "filters": [
      {
        "source": "message",
        "transform": "hasContent"
      }
    ],
    "author": [
      {
        "source": "message",
        "path": "message",
        "regex": "(?:^|\\n)\\s*By\\s+(.+?)(?:\\n|$)",
        "group": 1,
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "firstName",
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "username",
        "regex": "(.+)",
        "group": 1,
        "transform": "telegramUsername"
      }
    ],
    "likes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👍|❤|❤️|🔥|\\+)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ],
    "dislikes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👎|-)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ],
    "countLocale": "en-US",
    "fallbackReactions": {
      "likeMarkers": [
        "👍",
        "❤",
        "❤️",
        "🔥",
        "+"
      ],
      "dislikeMarkers": [
        "👎",
        "-"
      ]
    }
  },
  "publish": {
    "dryRun": false,
    "throttle": {
      "enabled": true,
      "perChatMinMs": 1100,
      "globalMinMs": 40,
      "sharedDestinationMinMs": 350,
      "shareRetryAfterAcrossBots": false,
      "retryBufferMs": 1000
    },
    "workerLeaseMs": 900000,
    "requestTtlHours": 12,
    "workerIntervalMinutes": 10,
    "sources": [
      {
        "key": "best",
        "where": "true"
      },
      {
        "key": "controversial",
        "where": "abs(likes - dislikes) < max(likes, dislikes) * 0.3"
      }
    ],
    "template": [
      {
        "source": "best",
        "key": "monthly_best",
        "enabled": true,
        "schedule": {
          "type": "monthly",
          "dayOfMonth": 1,
          "time": "10:20"
        },
        "windowHours": 720,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "best",
        "key": "weekly_best",
        "enabled": true,
        "schedule": {
          "type": "weekly",
          "weekday": 1,
          "time": "10:10"
        },
        "windowHours": 168,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "best",
        "key": "daily_best",
        "enabled": true,
        "schedule": {
          "type": "daily",
          "time": "10:00"
        },
        "windowHours": 24,
        "posts": {
          "target": 5,
          "min": 1,
          "max": 5
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best fresh posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "monthly_controversial",
        "enabled": true,
        "schedule": {
          "type": "monthly",
          "dayOfMonth": 1,
          "time": "11:20"
        },
        "windowHours": 720,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "weekly_controversial",
        "enabled": false,
        "schedule": {
          "type": "weekly",
          "weekday": 1,
          "time": "11:10"
        },
        "windowHours": 168,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "daily_controversial",
        "enabled": false,
        "schedule": {
          "type": "daily",
          "time": "11:00"
        },
        "windowHours": 24,
        "posts": {
          "target": 5,
          "min": 1,
          "max": 5
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial fresh posts for the last {{windowHours}}h ({{count}})"
      }
    ],
    "postMaxRetries": 3,
    "maxConsecutivePostFailures": 3,
    "retryBaseMs": 1000,
    "retryMaxMs": 60000,
    "requestMaxRetries": 3
  },
  "templates": {
    "publish": {
      "postCaption": "{{position}}. By {{author}}\n👍 {{likes}}  👎 {{dislikes}}\nMedia: {{mediaSummary}}\n\n{{text}}",
      "unknownAuthor": "unknown",
      "maxTextLength": 700
    },
    "stats": {
      "summary": "Database stats\nTotal posts: {{totalCount}}\nTotal reactions: 👍 {{totalLikes}}  👎 {{totalDislikes}}\nFresh in 24h: {{freshCount}}\nRefresh window: {{recentCount}} posts, 👍 {{recentLikes}}  👎 {{recentDislikes}}",
      "topPost": "Top month post: #{{messageId}}, 👍 {{likes}}  👎 {{dislikes}}"
    }
  },
  "schedule": {
    "enabled": true,
    "timezone": "Europe/Moscow"
  }
}
