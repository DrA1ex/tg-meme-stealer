{
  "telegram": {
    "sessionFile": "sessions/mtcute-user.session"
  },
  "database": {
    "path": "data/posts.sqlite"
  },
  "logging": {
    "logLevel": "INFO",
    "color": "auto"
  },
  "sync": {
    "initialScanDays": 60,
    "refreshRecentDays": 7,
    "pageSize": 100,
    "mediaDir": "tmp/media",
    "intervalHours": 6,
    "runOnStart": true,
    "retentionDays": 60,
    "retentionInitialDelayMinutes": 15,
    "retentionIntervalHours": 24,
    "throttle": {
      "enabled": true,
      "historyMinMs": 800,
      "historyMaxMs": 1800,
      "mediaMinMs": 300,
      "mediaMaxMs": 900
    }
  },
  "parsing": {
    "filters": [
      {
        "source": "message",
        "transform": "hasContent"
      }
    ],
    "author": [
      {
        "source": "message",
        "path": "message",
        "regex": "(?:^|\\n)\\s*By\\s+(.+?)(?:\\n|$)",
        "group": 1,
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "firstName",
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "username",
        "regex": "(.+)",
        "group": 1,
        "transform": "telegramUsername"
      }
    ],
    "likes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👍|❤|❤️|🔥|\\+)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ],
    "dislikes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👎|-)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ]
  },
  "publish": {
    "dryRun": false,
    "requestTtlHours": 12,
    "workerIntervalMinutes": 10,
    "sources": [
      {
        "key": "best",
        "where": "true"
      },
      {
        "key": "controversial",
        "where": "abs(likes - dislikes) < max(likes, dislikes) * 0.3"
      }
    ],
    "template": [
      {
        "source": "best",
        "key": "monthly_best",
        "enabled": true,
        "schedule": {
          "type": "monthly",
          "dayOfMonth": 1,
          "time": "10:20"
        },
        "windowHours": 720,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "best",
        "key": "weekly_best",
        "enabled": true,
        "schedule": {
          "type": "weekly",
          "weekday": 1,
          "time": "10:10"
        },
        "windowHours": 168,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "best",
        "key": "daily_best",
        "enabled": true,
        "schedule": {
          "type": "daily",
          "time": "10:00"
        },
        "windowHours": 24,
        "posts": {
          "target": 5,
          "min": 1,
          "max": 5
        },
        "reactions": {
          "strategy": "likes",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Best fresh posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "monthly_controversial",
        "enabled": true,
        "schedule": {
          "type": "monthly",
          "dayOfMonth": 1,
          "time": "11:20"
        },
        "windowHours": 720,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "weekly_controversial",
        "enabled": false,
        "schedule": {
          "type": "weekly",
          "weekday": 1,
          "time": "11:10"
        },
        "windowHours": 168,
        "posts": {
          "target": 10,
          "min": 1,
          "max": 10
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial posts for the last {{windowHours}}h ({{count}})"
      },
      {
        "source": "controversial",
        "key": "daily_controversial",
        "enabled": false,
        "schedule": {
          "type": "daily",
          "time": "11:00"
        },
        "windowHours": 24,
        "posts": {
          "target": 5,
          "min": 1,
          "max": 5
        },
        "reactions": {
          "strategy": "sum",
          "min": 0,
          "includeAbove": 999999
        },
        "template": "Most controversial fresh posts for the last {{windowHours}}h ({{count}})"
      }
    ]
  },
  "templates": {
    "publish": {
      "postCaption": "{{position}}. By {{author}}\n👍 {{likes}}  👎 {{dislikes}}\nMedia: {{mediaSummary}}\n\n{{text}}",
      "unknownAuthor": "unknown",
      "maxTextLength": 700
    },
    "stats": {
      "summary": "Database stats\nTotal posts: {{totalCount}}\nTotal reactions: 👍 {{totalLikes}}  👎 {{totalDislikes}}\nFresh in 24h: {{freshCount}}\nRefresh window: {{recentCount}} posts, 👍 {{recentLikes}}  👎 {{recentDislikes}}",
      "topPost": "Top month post: #{{messageId}}, 👍 {{likes}}  👎 {{dislikes}}"
    }
  },
  "schedule": {
    "enabled": true,
    "timezone": "Europe/Moscow"
  }
}
