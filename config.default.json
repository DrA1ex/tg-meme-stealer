{
  "telegram": {
    "sessionFile": "sessions/mtcute-user.session"
  },
  "database": {
    "path": "data/posts.sqlite"
  },
  "logging": {
    "logLevel": "INFO",
    "color": "auto"
  },
  "sync": {
    "initialScanDays": 60,
    "refreshRecentDays": 7,
    "pageSize": 100,
    "mediaDir": "tmp/media",
    "intervalHours": 6,
    "runOnStart": true,
    "retentionDays": 60,
    "retentionInitialDelayMinutes": 15,
    "retentionIntervalHours": 24,
    "throttle": {
      "enabled": true,
      "historyMinMs": 800,
      "historyMaxMs": 1800,
      "mediaMinMs": 300,
      "mediaMaxMs": 900
    }
  },
  "parsing": {
    "filters": [
      {
        "source": "message",
        "transform": "hasContent"
      }
    ],
    "author": [
      {
        "source": "message",
        "path": "message",
        "regex": "(?:^|\\n)\\s*By\\s+(.+?)(?:\\n|$)",
        "group": 1,
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "firstName",
        "transform": "trim"
      },
      {
        "source": "sender",
        "path": "username",
        "regex": "(.+)",
        "group": 1,
        "transform": "telegramUsername"
      }
    ],
    "likes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👍|❤|❤️|🔥|\\+)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ],
    "dislikes": [
      {
        "source": "message",
        "path": "replyMarkup.rows[].buttons[].text",
        "regex": "(?:👎|-)\\s*([\\d\\s,.]+[km]?)",
        "group": 1,
        "transform": "count",
        "aggregate": "sum"
      }
    ]
  },
  "publish": {
    "dryRun": false,
    "requestTtlHours": 12,
    "workerIntervalMinutes": 10,
    "template": [
      {
        "source": "best",
        "key": "month",
        "enabled": true,
        "time": "10:20",
        "limit": 10,
        "template": "Best posts from the last month ({{count}})"
      },
      {
        "source": "best",
        "key": "week",
        "enabled": true,
        "time": "10:10",
        "limit": 10,
        "template": "Best posts from the last week ({{count}})"
      },
      {
        "source": "best",
        "key": "day",
        "enabled": true,
        "time": "10:00",
        "limit": 5,
        "windowHours": 24,
        "template": "Best fresh posts ({{count}})"
      },
      {
        "source": "controversial",
        "key": "month",
        "enabled": true,
        "time": "11:20",
        "limit": 10,
        "threshold": 0.3,
        "template": "Most controversial posts from the last month ({{count}})"
      },
      {
        "source": "controversial",
        "key": "week",
        "enabled": false,
        "time": "11:10",
        "limit": 10,
        "threshold": 0.3,
        "template": "Most controversial posts from the last week ({{count}})"
      },
      {
        "source": "controversial",
        "key": "day",
        "enabled": false,
        "time": "11:00",
        "limit": 5,
        "windowHours": 24,
        "threshold": 0.3,
        "template": "Most controversial fresh posts ({{count}})"
      }
    ]
  },
  "templates": {
    "publish": {
      "postCaption": "{{position}}. By {{author}}\n👍 {{likes}}  👎 {{dislikes}}\nMedia: {{mediaSummary}}\n\n{{text}}",
      "unknownAuthor": "unknown",
      "maxTextLength": 700
    },
    "stats": {
      "summary": "Database stats\nTotal posts: {{totalCount}}\nTotal reactions: 👍 {{totalLikes}}  👎 {{totalDislikes}}\nFresh in 24h: {{freshCount}}\nRefresh window: {{recentCount}} posts, 👍 {{recentLikes}}  👎 {{recentDislikes}}",
      "topPost": "Top month post: #{{messageId}}, 👍 {{likes}}  👎 {{dislikes}}"
    }
  },
  "schedule": {
    "enabled": true,
    "timezone": "Europe/Moscow"
  }
}
